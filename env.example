# VERSION: v3.6.0 | DATE: 2026-04-23 | AUTHOR: VeloHub Development Team
# CHANGELOG: v3.6.0 - Sem credenciais reais; MONGO_ENV como fonte única; dev via FONTE DA VERDADE/.env
# Configurações do Backend - Console de Conteúdo VeloHub
#
# Produção (Cloud Run): definir MONGO_ENV e secrets via Secret Manager / variáveis do serviço.
# Desenvolvimento: usar C:\DEV - Ecosistema Velohub\FONTE DA VERDADE\.env (ou VELOHUB_DOTENV_PATH).

# Porta do servidor
PORT=3001

# Ambiente (development, production)
NODE_ENV=production

# MongoDB — URI completa (obrigatória). Nome do secret em PRD: MONGO_ENV
MONGO_ENV=mongodb+srv://REDACTED_ATLAS_URI

# Opcional: scripts legados que ainda leem MONGODB_URI
# MONGODB_URI=

MONGODB_DB_NAME=console_conteudo

# Console Chamados Database
CONSOLE_CHAMADOS_DB=console_chamados

# Console Config Database (para usuários autorizados)
CONSOLE_CONFIG_DB=console_config

# Console Analises Database (para módulo de qualidade)
CONSOLE_ANALISES_DB=console_analises

# CORS (o server.js atual usa origin *; ajuste se passar a usar CORS_ORIGIN no código)
# CORS_ORIGIN=https://front-console.vercel.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security (verificar se o middleware usa estes nomes antes de definir em PRD)
# JWT_SECRET=
# API_KEY=

# Google Cloud Platform Configuration
GCP_PROJECT_ID=velohub-471220

# Google Cloud Storage Bucket Name
GCS_BUCKET_NAME=qualidade_audio_envio

# Google Cloud Service Account Key (JSON string) — preferir Secret Manager em PRD
# GCP_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
